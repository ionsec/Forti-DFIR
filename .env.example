# Forti-DFIR Environment Configuration
# Copy this file to .env and fill in your values

# =========================================
# REQUIRED - Security Settings
# =========================================

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-change-me-in-production

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=your-jwt-secret-key-change-me-in-production

# =========================================
# REQUIRED - Admin Credentials (First Run)
# =========================================

# Initial admin user (change these!)
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeThisToAStr0ngPassword!

# =========================================
# Application Settings
# =========================================

# Environment: development or production
FLASK_ENV=development

# Debug mode (set to False in production)
FLASK_DEBUG=False

# Server port
PORT=5000

# =========================================
# CORS Settings
# =========================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# =========================================
# Redis Settings
# =========================================

# Redis URL for Celery and rate limiting
REDIS_URL=redis://localhost:6379/0

# =========================================
# Rate Limiting
# =========================================

# Default rate limit
RATELIMIT_DEFAULT=200 per day;50 per hour

# Login rate limit
RATELIMIT_LOGIN=5 per minute

# Parse rate limit
RATELIMIT_PARSE=10 per minute

# =========================================
# Database (Future Use)
# =========================================

# Database URL (uncomment to enable)
# DATABASE_URL=sqlite:///forti_dfir.db
# DATABASE_URL=postgresql://user:password@localhost/forti_dfir

# =========================================
# Logging
# =========================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/forti_dfir.log
